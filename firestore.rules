rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields: email, displayName, photoURL, stage, clinicalStage, createdAt
    //
    // Collection: /users/{userId}/memories/{memoryId}
    // Fields: userId, sessionId, text, mediaUrl, tags, emotionalValence, status, createdAt, audioUrl, photoUrl
    //
    // Collection: /users/{userId}/sessions/{sessionId}
    // Fields: userId, type, startedAt, endedAt, summary, qualityScore, participants, tags, audioUrl
    //
    // Collection: /users/{userId}/consent/{consentId}
    // Fields: userId, status, signedHash, permissions, createdAt
    //
    // Collection: /users/{userId}/pimLayers/{layerId}
    // Sub-collections: identityLayer, narrativeLayer, relationalLayer, valuesLayer
    //
    // Collection: /users/{userId}/familyMembers/{memberId}
    // Collection: /users/{userId}/familyContributions/{contribId}
    // Collection: /users/{userId}/sharedMoments/{momentId}
    // Collection: /users/{userId}/lucidWindow/{windowId}
    // Collection: /users/{userId}/biometricTokens/{tokenId}
    // Collection: /users/{userId}/consentEvents/{eventId}
    // Collection: /users/{userId}/cognitiveMetrics/{metricId}
    //
    // Top-Level Collection: /familyInvites/{inviteId}
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDefaultAdmin() {
      return isAuthenticated() && request.auth.token.email == "vibhagoparaju@gmail.com";
    }

    // Validate string length
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // Validate that a field is either a timestamp or a valid date string
    function isValidTemporal(field) {
      return request.resource.data[field] is timestamp || (request.resource.data[field] is string && request.resource.data[field].size() > 10);
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'displayName', 'stage']) &&
             data.email is string &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.stage in ['PLANNER', 'DECLINING', 'CAREGIVER', 'LEGACY'];
    }

    function isValidMemory(data) {
      return data.keys().hasAll(['text']) &&
             data.text is string && data.text.size() < 20000;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['type']) &&
             data.type in ['CAPTURE', 'BRIDGE'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isDefaultAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);

      match /memories/{memoryId} {
        allow read: if isOwner(userId) || isDefaultAdmin();
        allow create: if isOwner(userId) && isValidMemory(request.resource.data);
        allow update: if isOwner(userId) && isValidMemory(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /sessions/{sessionId} {
        allow read: if isOwner(userId) || isDefaultAdmin();
        allow create: if isOwner(userId) && isValidSession(request.resource.data);
        allow update: if isOwner(userId) && isValidSession(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /consent/{consentId} {
        allow read: if isOwner(userId) || isDefaultAdmin();
        allow create: if isOwner(userId);
      }

      // singleton/active documents
      match /pimLayers/{docId} {
        allow read: if isOwner(userId) || isDefaultAdmin();
        allow write: if isOwner(userId);
      }

      match /lucidWindow/{docId} {
        allow read: if isOwner(userId) || isDefaultAdmin();
        allow write: if isOwner(userId);
      }

      match /familyMembers/{memberId} {
        allow read: if isOwner(userId) || isDefaultAdmin();
        allow write: if isOwner(userId);
      }

      match /familyContributions/{contribId} {
        allow read: if isOwner(userId) || isDefaultAdmin();
        allow write: if isOwner(userId);
      }

      match /sharedMoments/{momentId} {
        allow read: if isOwner(userId) || isDefaultAdmin();
        allow write: if isOwner(userId);
      }

      match /biometricTokens/{tokenId} {
        allow read: if isOwner(userId) || isDefaultAdmin();
        allow write: if isOwner(userId);
      }

      match /consentEvents/{eventId} {
        allow read: if isOwner(userId) || isDefaultAdmin();
        allow write: if isOwner(userId);
      }

      match /cognitiveMetrics/{metricId} {
        allow read: if isOwner(userId) || isDefaultAdmin();
        allow write: if isOwner(userId);
      }
    }

    match /familyInvites/{inviteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }
  }
}
